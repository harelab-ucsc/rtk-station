[Unit]
Description=GNSS To NTRIP Server (NTRIPv1 - ICY 200 OK)
After=gnss_server.service rtk-log-setup.service
Requires=gnss_server.service rtk-log-setup.service

[Service]
ExecStart=/usr/local/bin/rtk-log-run gnss_to_ntrip /usr/local/bin/ntrip-server
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
